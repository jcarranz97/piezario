# --- Node / Next.js -------------------------------------------------------
node_modules/
.next/
out/
*.tsbuildinfo
.env*.local

# --- Test output ----------------------------------------------------------
coverage/
.pytest_cache/

# The test fixture vault must be committed verbatim — including its `out/`
# folder, which the global `out/` rule above would otherwise drop.
!web/tests/fixtures/**/out/

# --- Electron build -------------------------------------------------------
desktop/staging/
desktop/dist/

# --- Python (thumbnail CLI, dev-only) -------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
