{
  "name": "piezario-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for Piezario — runs the Next.js web app as a desktop app.",
  "main": "main.js",
  "scripts": {
    "dev": "NEXT_DEV=1 electron . --no-sandbox",
    "build:web": "npm --prefix ../web install && npm --prefix ../web run build",
    "stage": "node stage.js",
    "buildinfo": "node build-info.js",
    "repack": "node repack-appimage.js",
    "build:linux": "npm run build:web && npm run stage && npm run buildinfo && electron-builder --linux AppImage && npm run repack",
    "install:linux": "./install-linux.sh",
    "uninstall:linux": "./install-linux.sh --uninstall",
    "build:win": "npm run build:web && npm run stage && npm run buildinfo && electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.piezario.app",
    "productName": "Piezario",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build-info.json"
    ],
    "extraResources": [
      {
        "from": "staging/app-server",
        "to": "app-server"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Graphics",
      "icon": "build/icon.png",
      "desktop": {
        "StartupWMClass": "piezario-desktop"
      },
      "executableArgs": [
        "--no-sandbox"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
